{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "es2020",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "outDir": "./dist",
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "generated/**/*"]
}
